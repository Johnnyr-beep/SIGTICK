{% extends 'layout/page_login_santacruz.html.twig' %}

{% block content_block %}
    <style>
        @keyframes santacruz-shake {
            0%, 100% { transform: translateX(0); }
            20% { transform: translateX(-8px); }
            40% { transform: translateX(8px); }
            60% { transform: translateX(-6px); }
            80% { transform: translateX(6px); }
        }
        .santacruz-shake { animation: santacruz-shake 0.45s ease-in-out; }
        #login-error-banner { transition: opacity .2s ease-in-out; }
    </style>

    <div id="login-error-banner" class="alert alert-danger d-none mb-3 py-2" role="alert">
        <div class="d-flex align-items-center">
            <i class="ti ti-alert-circle-filled fs-3 me-2"></i>
            <div id="login-error-text" class="flex-grow-1">{{ __('Usuario o contraseña incorrectos.') }}</div>
        </div>
    </div>

    <form id="santacruz-login-form" action="{{ path('front/login.php') }}" method="post" autocomplete="off">
        <input type="hidden" name="noAUTO" value="{{ noAuto }}"/>
        <input type="hidden" name="redirect" value="{{ redirect }}"/>
        <input type="hidden" name="_glpi_csrf_token" value="{{ csrf_token() }}"/>
        {% if text_login|length > 0 %}
            <div class="rich_text_container text-center mb-3">
                {{ text_login|safe_html }}
            </div>
        {% endif %}

        <div class="mb-3">
            <label class="form-label" for="login_name">{{ __('Usuario') }}</label>
            <input type="text" class="form-control" id="login_name" name="login_name" placeholder="usuario.santacruz" tabindex="1"/>
        </div>

        <div class="mb-3">
            <div class="d-flex">
                <label class="form-label" for="login_password">{{ __('Contraseña') }}</label>
                {% if show_lost_password %}
                    <span class="ms-auto forgot_password">
                        <a href="{{ path('front/lostpassword.php?lostpassword=1') }}">
                            {{ __('¿Olvidó su contraseña?') }}
                        </a>
                    </span>
                {% endif %}
            </div>
            <input type="password" class="form-control" id="login_password" name="login_password" placeholder="••••••••" autocomplete="off" tabindex="2"/>
        </div>

        {% if false and config('display_login_source') %}
            <div class="mb-3">
                <label class="form-label" for="dropdown_auth{{ rand }}">{{ __('Login source') }}</label>
                {{ auth_dropdown_login|raw }}
            </div>
        {% endif %}

        {% if config('login_remember_time') %}
            <div class="mb-3">
                <label class="form-check" for="login_remember">
                    <input type="checkbox" class="form-check-input" id="login_remember" name="login_remember" {{ config('login_remember_default') ? 'checked' : '' }}/>
                    <span class="form-check-label">{{ __('Recordarme') }}</span>
                </label>
            </div>
        {% endif %}

        <div class="form-footer">
            <button type="submit" name="submit" class="btn btn-primary w-100" tabindex="3">
                <i class="ti ti-login me-1"></i> {{ __('Ingresar') }}
            </button>
        </div>

        {% if right_panel %}
            <div class="mt-3 text-center">
                {{ call_plugin_hook(constant('Glpi\\Plugin\\Hooks::DISPLAY_LOGIN')) }}
            </div>
        {% endif %}

        {% if config('use_public_faq') %}
            <div class="text-center mt-3">
                <a class="btn btn-outline-secondary btn-sm" href="{{ path('front/helpdesk.faq.php') }}">
                    <i class="ti ti-help"></i>&nbsp;{{ __('Preguntas frecuentes') }}
                </a>
            </div>
        {% endif %}
    </form>
{% endblock %}

{% block footer_block %}
    {% if must_call_cron %}
        <div style="background-image: url('{{ path('/front/cron.php') }}');"></div>
    {% endif %}
{% endblock %}

{% block javascript_block %}
    <script type="text/javascript">
        $(function () {
            $('#login_name').focus();

            const form        = document.getElementById('santacruz-login-form');
            const banner      = document.getElementById('login-error-banner');
            const bannerText  = document.getElementById('login-error-text');
            const submitBtn   = form.querySelector('button[type="submit"]');
            const pwdInput    = document.getElementById('login_password');
            const userInput   = document.getElementById('login_name');
            const csrfInput   = form.querySelector('input[name="_glpi_csrf_token"]');
            const originalBtn = submitBtn.innerHTML;
            const errLabel    = {{ __('Usuario o contraseña incorrectos.')|json_encode|raw }};
            const netLabel    = {{ __('Error de conexión. Intente nuevamente.')|json_encode|raw }};
            const loadingLbl  = {{ __('Ingresando...')|json_encode|raw }};

            function showError(msg) {
                bannerText.textContent = msg || errLabel;
                banner.classList.remove('d-none');
                form.classList.remove('santacruz-shake');
                void form.offsetWidth;
                form.classList.add('santacruz-shake');
                pwdInput.value = '';
                pwdInput.focus();
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalBtn;
            }

            function hideError() {
                banner.classList.add('d-none');
            }

            [userInput, pwdInput].forEach(function (el) {
                el.addEventListener('input', hideError);
            });

            form.addEventListener('submit', function (e) {
                e.preventDefault();
                if (submitBtn.disabled) {
                    return;
                }
                hideError();
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>' + loadingLbl;

                const formData = new FormData(form);

                fetch(form.action, {
                    method: 'POST',
                    body: formData,
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-Glpi-Csrf-Token': csrfInput.value,
                        'Accept': 'application/json, text/html'
                    },
                    credentials: 'same-origin',
                    redirect: 'follow'
                }).then(function (response) {
                    if (response.status === 400) {
                        return response.json().then(function (data) {
                            const msg = (data && Array.isArray(data.errors) && data.errors.length)
                                ? data.errors.join(' ')
                                : errLabel;
                            showError(msg);
                        }).catch(function () {
                            showError(errLabel);
                        });
                    }
                    if (response.ok || response.redirected) {
                        window.location.href = response.url || window.location.href;
                        return;
                    }
                    showError(errLabel);
                }).catch(function () {
                    showError(netLabel);
                });
            });
        });
    </script>
{% endblock %}
